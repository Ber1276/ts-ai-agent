// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum DocumentStatus {
  PENDING
  PARSED
  INDEXED
  FAILED
}

enum RagRetrieverMode {
  KEYWORD
  VECTOR
  HYBRID
}

enum RagVectorStore {
  DATABASE
  MEMORY
  PGVECTOR
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  STREAMING
  SUCCEEDED
  FAILED
  CANCELED
}

enum TaskStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model User {
  id            String              @id @default(cuid())
  email         String              @unique
  name          String?
  knowledgeBase KnowledgeBase[]
  conversations Conversation[]
  agents        Agent[]
  modelServices ModelServiceConfig[]
  createdAt     DateTime            @default(now())

  @@index([createdAt])
}

model ModelServiceConfig {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  label     String
  endpoint  String
  model     String
  apiKey    String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isDefault, createdAt])
  @@index([userId, isActive, createdAt])
}

model KnowledgeBase {
  id          String        @id @default(cuid())
  name        String
  description String?
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  documents   Document[]
  ragConfig   RagConfig?
  createdAt   DateTime      @default(now())

  @@index([userId, createdAt])
}

model RagConfig {
  id                  String          @id @default(cuid())
  knowledgeBase       KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id])
  knowledgeBaseId     String          @unique
  retrieverMode       RagRetrieverMode @default(KEYWORD)
  vectorStore         RagVectorStore  @default(DATABASE)
  chunkSize           Int             @default(1000)
  chunkOverlap        Int             @default(120)
  topK                Int             @default(6)
  minScore            Float           @default(0.2)
  embeddingEndpoint   String?
  embeddingModel      String?
  embeddingApiKey     String?
  embeddingDimensions Int?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([knowledgeBaseId, retrieverMode, vectorStore])
}

model Document {
  id              String         @id @default(cuid())
  title           String
  content         String
  status          DocumentStatus @default(PENDING)
  knowledgeBase   KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id])
  knowledgeBaseId String
  createdAt       DateTime       @default(now())
  chunks          DocumentChunk[]

  @@index([knowledgeBaseId, status, createdAt])
}

model DocumentChunk {
  id           String                 @id @default(cuid())
  content      String
  document     Document               @relation(fields: [documentId], references: [id])
  documentId   String
  embedding    DocumentChunkEmbedding?
  createdAt    DateTime               @default(now())
  referencedIn Message[]
  retrievalHits RetrievalHit[]

  @@index([documentId, createdAt])
}

model DocumentChunkEmbedding {
  id         String        @id @default(cuid())
  chunk      DocumentChunk @relation(fields: [chunkId], references: [id])
  chunkId    String        @unique
  vector     Json
  dimensions Int
  provider   String
  model      String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([model, createdAt])
}

model Conversation {
  id        String     @id @default(cuid())
  title     String
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  messages  Message[]
  runs      AgentRun[]
  createdAt DateTime   @default(now())

  @@index([userId, createdAt])
}

model Message {
  id             String          @id @default(cuid())
  content        String
  role           MessageRole
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  conversationId String
  createdAt      DateTime        @default(now())
  sources        DocumentChunk[]

  @@index([conversationId, createdAt])
}

model Agent {
  id           String     @id @default(cuid())
  name         String
  description  String?
  systemPrompt String?
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  runs         AgentRun[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId, createdAt])
  @@unique([userId, name])
}

model AgentRun {
  id            String         @id @default(cuid())
  agent         Agent          @relation(fields: [agentId], references: [id])
  agentId       String
  conversation  Conversation?  @relation(fields: [conversationId], references: [id])
  conversationId String?
  status        AgentRunStatus @default(QUEUED)
  input         String
  outputSummary String?
  startedAt     DateTime?
  finishedAt    DateTime?
  events        Json?
  retrievalHits RetrievalHit[]
  tasks         Task[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([agentId, status, createdAt])
  @@index([conversationId, createdAt])
}

model RetrievalHit {
  id              String        @id @default(cuid())
  agentRun        AgentRun      @relation(fields: [agentRunId], references: [id])
  agentRunId      String
  documentChunk   DocumentChunk @relation(fields: [documentChunkId], references: [id])
  documentChunkId String
  score           Float
  snippet         String?
  createdAt       DateTime      @default(now())

  @@index([agentRunId, score])
  @@index([documentChunkId])
}

model Task {
  id         String     @id @default(cuid())
  agentRun   AgentRun   @relation(fields: [agentRunId], references: [id])
  agentRunId String
  type       String
  payload    Json?
  status     TaskStatus @default(QUEUED)
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?
  createdAt  DateTime   @default(now())

  @@index([agentRunId, status, createdAt])
  @@index([status, createdAt])
}
