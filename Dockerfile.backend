# --- Build Stage ---
FROM node:22-alpine AS builder

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy root configuration files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
# Copy required packages
COPY packages/share ./packages/share
COPY packages/backend ./packages/backend
COPY prisma ./prisma

# Install all dependencies (we need them to build)
RUN pnpm install --frozen-lockfile

# Build the project
# We need share built first because backend depends on it
RUN pnpm --filter share build
# Generate Prisma Client
RUN pnpm db:generate
# Build backend
RUN pnpm --filter agent-server build

# --- Runtime Stage ---
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

# Copy built files and node_modules from builder
# Note: In production, we could prune dev dependencies, but for now we'll keep it simple
COPY --from=builder /app /app

EXPOSE 3000

# Start the server
CMD ["node", "packages/backend/dist/index.js"]
