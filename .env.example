# Server
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ts_ai_agent_db

# Optional seed identity for Prisma run store
CHAT_RUN_STORE_USER_EMAIL=dev@local.agent
CHAT_RUN_STORE_USER_NAME=Dev User
CHAT_RUN_STORE_AGENT_NAME=default-agent

# Optional external model streaming config
LLM_API_ENDPOINT=
LLM_API_MODEL=
LLM_API_KEY=
# Stream timeout in milliseconds (default 180000)
CHAT_STREAM_TIMEOUT_MS=180000

# Optional model presets (JSON array)
# MODEL_SERVICE_PRESETS_JSON=[{"id":"openai","label":"OpenAI","endpoint":"https://api.openai.com/v1/chat/completions","model":"gpt-4o-mini","apiKeyEnv":"OPENAI_API_KEY"}]
MODEL_SERVICE_PRESETS_JSON=
OPENAI_API_KEY=

# RAG core
RAG_RETRIEVER_MODE=keyword
# database | memory | pgvector
RAG_VECTOR_STORE=database
RAG_MAX_UPLOAD_BYTES=10485760
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_MIN_SCORE=0.2

# Embedding config (OpenAI-compatible)
RAG_EMBEDDING_ENDPOINT=
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_DIMENSIONS=1536

# Optional self-check override
BACKEND_BASE_URL=http://localhost:3101
